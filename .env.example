# Copy this file to .env and fill the values locally.
# Never commit .env with real secrets.

# AI provider routing
DEFAULT_AI_PROVIDER=local
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Backward-compatible aliases. Prefer DEFAULT_AI_PROVIDER and GEMINI_MODEL.
# LLM_PROVIDER=local
# LLM_MODEL=gemini-2.5-flash
# GOOGLE_API_KEY=

# Local storage
DATABASE_URL=sqlite:///data/sotuhire.db

# Responsible scraping defaults
SOTUHIRE_USER_AGENT=SotuHireBot/0.1 (+https://github.com/Soturine/SotuHire)
SCRAPING_ENABLED=false
OBEY_ROBOTS_TXT=true
REQUEST_DELAY_SECONDS=3
MAX_PAGES_PER_SOURCE=20
CACHE_ENABLED=true

# Debug
LOG_LEVEL=INFO

# Optional alert integrations
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional AI providers
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Optional local storage
SOTUHIRE_DB_PATH=data/sotuhire.sqlite3
SOTUHIRE_VECTOR_STORE_PATH=data/vector_store

# Optional future AI providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Local companion app / extension future config
SOTUHIRE_LOCAL_API_URL=http://127.0.0.1:8000
ENABLE_BROWSER_EXTENSION=false

# Optional modules
ENABLE_PUBLIC_EXAMS_MODE=false
ENABLE_ADVANCED_ML=false
